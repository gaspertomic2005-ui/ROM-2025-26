  RowBox[{
   RowBox[{"Sin", "[", "x", "]"}], "+", 
   RowBox[{
    RowBox[{"x", "^", "5"}], "/", "5"}]}]}], "\n", 
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"g", "[", "x", "]"}], "==", 
