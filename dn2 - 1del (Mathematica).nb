Cell[TextData[{
 "a)  Definirajte funkcijo A(m,n), ki sprejme naravni \[SHacek]tevili ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
