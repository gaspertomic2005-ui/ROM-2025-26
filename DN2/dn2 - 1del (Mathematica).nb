Cell[TextData[{
 "a) Izra\[CHacek]unajte neskon\[CHacek]no vsoto 1+1/9+1/25+1/49+1/81+...\nb) \
Izra\[CHacek]unajte limito funkcije \n\t\tf(x) = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"sin", 
       RowBox[{"(", "x", ")"}]}], "-", "x"}], ")"}], 
    SuperscriptBox["x", "3"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "63aa3d09-c712-4c4c-926b-97ed6eedddac"],
 ",\n    ko gre x proti 0.\nc) Izra\[CHacek]unajte plo\[SHacek]\[CHacek]ino \
lika, ki ga omejujejo graf funkcije g(x) = sin(x)+x^2, abscisna os ter navpi\
\[CHacek]nici x=0 in x=2\[Pi].\nd) Izra\[CHacek]unajte \
plo\[SHacek]\[CHacek]ino lika, ki ga omejujeta grafa funkcij g(x) = \
sin(x)+x^2 in g1(x) = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"sin", "(", "x", ")"}], " ", "+", " ", 
    FractionBox[
     SuperscriptBox["x", "5"], "5"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f96a6f80-a9ec-4142-bedd-7cd1d677cfe0"],
 ". "
}], "Text",
 CellChangeTimes->{{3.987745712487891*^9, 3.987745729609254*^9}, {
  3.9877458487604876`*^9, 3.987745924618517*^9}, {3.987745987446829*^9, 
  3.9877460356962476`*^9}, {3.9877462163343086`*^9, 3.987746285694676*^9}, {
  3.987746397648479*^9, 3.9877464118858533`*^9}, {3.9877465268465223`*^9, 
  3.9877465297794733`*^9}, {3.987746756828573*^9, 3.9877467781909933`*^9}, {
  3.9877487966535535`*^9, 3.9877488023549*^9}, {3.987748882668123*^9, 
  3.9877489510271893`*^9}},ExpressionUUID->"e6d4a756-fca4-4306-9a89-\
0a5c4eda8912"]
}, Open  ]],

